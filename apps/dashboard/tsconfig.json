{
  "extends": "@midday/tsconfig/nextjs.json",
  "compilerOptions": {
    "paths": {
      "@/*": ["./src/*"],
      "@api/*": ["../api/src/*"],
      "@jobs/*": ["../../packages/jobs/src/*"],
      "@midday/supabase/cached-queries": ["./src/lib/supabase/cached-queries.ts"],
      "@midday/supabase/client": ["./src/lib/supabase/client.ts"],
      "@midday/supabase/mutations": ["./src/lib/supabase/mutations.ts"],
      "@midday/supabase/server": ["./src/lib/supabase/server.ts"]
    },
    "strict": true
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "../../types",
    "next-env.d.ts",
    "next.config.js",
    "tailwind.config.ts",
    ".next/types/**/*.ts"
  ],
  "exclude": ["node_modules", ".next"]
}
