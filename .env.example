# =============================================================================
# MIDDAY PROJECT - ENVIRONMENT VARIABLES
# =============================================================================
# Copy this file to .env.local and fill in your actual values
# This file contains dummy/example values for reference

# =============================================================================
# SUPABASE - Database & Authentication
# =============================================================================
# How to get: https://supabase.com/dashboard
# 1. Create a new project at https://supabase.com
# 2. Go to Project Settings > API
# 3. Copy the URL and keys
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_supabase_anon_key_here
NEXT_PUBLIC_SUPABASE_ID=your_project_id_here
SUPABASE_SECRET_KEY=your_supabase_service_role_key_here

# =============================================================================
# APPLICATION URLS
# =============================================================================
NEXT_PUBLIC_URL=http://localhost:3001
NEXT_PUBLIC_API_URL=http://localhost:3003

# =============================================================================
# REDIS - Caching (Upstash)
# =============================================================================
# How to get: https://upstash.com/
# 1. Create account at Upstash
# 2. Create a Redis database
# 3. Copy the REST URL and token
REDIS_URL=redis://localhost:6379
UPSTASH_REDIS_REST_URL=your_upstash_redis_url_here
UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_token_here

# =============================================================================
# EMAIL - Resend
# =============================================================================
# How to get: https://resend.com/
# 1. Sign up at Resend
# 2. Go to API Keys section
# 3. Create a new API key
RESEND_API_KEY=re_your_resend_api_key_here
RESEND_AUDIENCE_ID=your_audience_id_here

# =============================================================================
# BANKING CONNECTIONS - Teller
# =============================================================================
# How to get: https://teller.io/
# 1. Sign up for Teller account
# 2. Get your application ID and certificates
# 3. Download certificate and private key
TELLER_CERTIFICATE=your_base64_encoded_certificate_here
TELLER_CERTIFICATE_PRIVATE_KEY=your_base64_encoded_private_key_here
NEXT_PUBLIC_TELLER_APPLICATION_ID=your_teller_app_id_here
NEXT_PUBLIC_TELLER_ENVIRONMENT=sandbox
TELLER_SIGNING_SECRET=your_teller_signing_secret_here

# =============================================================================
# BANKING CONNECTIONS - Plaid
# =============================================================================
# How to get: https://plaid.com/
# 1. Sign up for Plaid account
# 2. Go to Dashboard > Team Settings > Keys
# 3. Copy client_id and secret
PLAID_CLIENT_ID=your_plaid_client_id_here
PLAID_SECRET=your_plaid_secret_here
NEXT_PUBLIC_PLAID_ENVIRONMENT=sandbox

# =============================================================================
# AI - OpenAI
# =============================================================================
# How to get: https://platform.openai.com/
# 1. Create OpenAI account
# 2. Go to API Keys section
# 3. Create new secret key
OPENAI_API_KEY=sk-your_openai_api_key_here

# =============================================================================
# CUSTOMER SUPPORT - Plain
# =============================================================================
# How to get: https://plain.com/
# 1. Sign up for Plain account
# 2. Go to Settings > API Keys
# 3. Create new API key
PLAIN_API_KEY=your_plain_api_key_here

# =============================================================================
# ANALYTICS - OpenPanel
# =============================================================================
# How to get: https://openpanel.dev/
# 1. Create OpenPanel account
# 2. Create new project
# 3. Copy client ID and secret key
NEXT_PUBLIC_OPENPANEL_CLIENT_ID=your_openpanel_client_id_here
OPENPANEL_SECRET_KEY=your_openpanel_secret_key_here

# =============================================================================
# WEBHOOKS
# =============================================================================
# Generate a random secret key for webhook verification
WEBHOOK_SECRET_KEY=your_webhook_secret_key_here

# =============================================================================
# DOCUMENT PROCESSING - Azure
# =============================================================================
# How to get: https://portal.azure.com/
# 1. Create Azure account
# 2. Create "Form Recognizer" or "Document Intelligence" resource
# 3. Go to Keys and Endpoint
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=https://your-resource.cognitiveservices.azure.com/
AZURE_DOCUMENT_INTELLIGENCE_KEY=your_azure_key_here

# =============================================================================
# MAPS - Google Maps
# =============================================================================
# How to get: https://console.cloud.google.com/
# 1. Create Google Cloud project
# 2. Enable Maps JavaScript API
# 3. Create API key in Credentials
NEXT_PUBLIC_GOOGLE_API_KEY=your_google_maps_api_key_here

# =============================================================================
# INVOICING
# =============================================================================
# Generate a random secret for JWT signing
# Example: openssl rand -base64 32
INVOICE_JWT_SECRET=your_invoice_jwt_secret_here

# =============================================================================
# CACHE API
# =============================================================================
# Generate a random secret for cache API
MIDDAY_CACHE_API_SECRET=your_cache_api_secret_here

# =============================================================================
# PAYMENTS - Polar
# =============================================================================
# How to get: https://polar.sh/
# 1. Create Polar account
# 2. Go to Settings > API
# 3. Create access token
POLAR_ACCESS_TOKEN=your_polar_access_token_here
POLAR_ENVIRONMENT=sandbox
POLAR_WEBHOOK_SECRET=your_polar_webhook_secret_here

# =============================================================================
# PAYMENTS - Stripe
# =============================================================================
# How to get: https://dashboard.stripe.com/
# 1. Create Stripe account
# 2. Go to Developers > API keys
# 3. Copy publishable and secret keys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here

# =============================================================================
# ERROR TRACKING - Sentry (Optional)
# =============================================================================
# How to get: https://sentry.io/
# 1. Create Sentry account
# 2. Create new project
# 3. Copy DSN from project settings
NEXT_PUBLIC_SENTRY_DSN=your_sentry_dsn_here

# =============================================================================
# FILE ENCRYPTION
# =============================================================================
# Generate a random secret for file encryption
FILE_KEY_SECRET=your_file_encryption_secret_here

# =============================================================================
# EMAIL INTEGRATION - Gmail
# =============================================================================
# How to get: https://console.cloud.google.com/
# 1. Create Google Cloud project
# 2. Enable Gmail API
# 3. Create OAuth 2.0 credentials
# 4. Add redirect URI: http://localhost:3003/apps/gmail/oauth-callback
GMAIL_CLIENT_ID=your_gmail_client_id_here
GMAIL_CLIENT_SECRET=your_gmail_client_secret_here
GMAIL_REDIRECT_URI=http://localhost:3003/apps/gmail/oauth-callback

# =============================================================================
# EMAIL INTEGRATION - Outlook
# =============================================================================
# How to get: https://portal.azure.com/
# 1. Go to Azure Active Directory > App registrations
# 2. Create new registration
# 3. Add redirect URI: http://localhost:3003/apps/outlook/oauth-callback
# 4. Create client secret
OUTLOOK_CLIENT_ID=your_outlook_client_id_here
OUTLOOK_CLIENT_SECRET=your_outlook_client_secret_here
OUTLOOK_REDIRECT_URI=http://localhost:3003/apps/outlook/oauth-callback

# =============================================================================
# DESKTOP APP
# =============================================================================
# Desktop deep link scheme (midday, midday-dev, midday-staging)
NEXT_PUBLIC_DESKTOP_SCHEME=midday-dev

# =============================================================================
# NEXT.JS SECURITY
# =============================================================================
# Next.js Server Actions encryption key (base64-encoded, 32 bytes)
# Generate with: openssl rand -base64 32
# IMPORTANT: Must be identical across all replicas/regions
NEXT_SERVER_ACTIONS_ENCRYPTION_KEY=your_base64_encryption_key_here

# =============================================================================
# MESSAGING APPS
# =============================================================================
# How to get WhatsApp: https://business.whatsapp.com/
# How to get Telegram: https://core.telegram.org/bots
# How to get Sendblue: https://sendblue.co/
NEXT_PUBLIC_WHATSAPP_NUMBER=+1234567890
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=your_bot_username
NEXT_PUBLIC_SENDBLUE_NUMBER=+1234567890

# =============================================================================
# NOTES
# =============================================================================
# - For local development, you can use dummy values for most services
# - For production, all values must be real and secure
# - Never commit .env.local with real credentials to version control
# - Use environment-specific files: .env.local, .env.production, etc.
