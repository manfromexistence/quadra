# Minimal Vercel Ignore - Only exclude truly unnecessary files

# Node modules (will be installed by Vercel)
**/node_modules/

# Build caches (will be rebuilt)
**/.next/
**/.turbo/
**/.cache/
.cache-f-drive/

# Test files
**/__tests__/
**/*.test.ts
**/*.test.tsx
**/*.spec.ts
**/*.spec.tsx
**/__mocks__/
**/__fixtures__/
**/evals/
coverage/

# IDE files
.vscode/
.idea/
.cursor/
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Git
.git/

# CI/CD
.github/

# Documentation
docs/
*.md
!README.md

# Project-specific
.hex/
.kiro/
**/.kiro/

# Large media files only
*.mp4
*.mov
*.avi
*.mkv
*.webm
*.zip
*.tar
*.gz
*.rar
*.7z
*.dmg
*.iso

# Keep everything else including:
# - packages/ (source code)
# - apps/ (source code) 
# - dist/ (built packages)
# - drizzle/ (database schemas)
# - All config files
# - All source files