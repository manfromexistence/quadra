# Vercel Ignore Configuration
# Excludes large folders and build artifacts while keeping all media assets

# Node modules and dependencies
node_modules/
**/node_modules/
.pnp
.pnp.js

# Build outputs and caches
.next/
out/
dist/
build/
.turbo/
**/.turbo/
.cache/
**/.cache/
.cache-f-drive/
**/.cache-f-drive/
*.tsbuildinfo
**/*.tsbuildinfo

# Testing
coverage/
.nyc_output/
**/__tests__/
**/*.test.ts
**/*.test.tsx
**/*.spec.ts
**/*.spec.tsx
**/__mocks__/
**/__fixtures__/
**/evals/

# Development files
.env.local
.env.development.local
.env.test.local
.env.production.local

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# IDE
.vscode/
.idea/
.cursor/
*.swp
*.swo
*~

# Git
.git/
.gitignore
.gitattributes

# CI/CD
.github/
.gitlab-ci.yml
.travis.yml
.circleci/

# Documentation (except README)
docs/
*.md
!README.md

# Project-specific folders
.hex/
.kiro/
**/.kiro/
.husky/

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Vercel
.vercel/

# Database files
*.db
*.sqlite
*.sqlite3
drizzle/
**/drizzle/

# Docker
Dockerfile
docker-compose*.yml
.dockerignore

# Scripts and tools
scripts/
tools/

# Storybook
.storybook/
storybook-static/

# Sentry
.sentryclirc

# Desktop apps
src-tauri/
.expo/

# Railway
railway.json

# SQL seed files
seed-*.sql
create-account.sql
